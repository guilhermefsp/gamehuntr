# Database
# Local:       postgresql+asyncpg://gamehunter:gamehunter@localhost:5432/gamehunter
# Neon (prod): postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://gamehunter:gamehunter@localhost:5432/gamehunter

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ludopedia
LUDOPEDIA_ACCESS_TOKEN=your_ludopedia_token_here

# BoardGameGeek XML API2 (Authorization: Bearer <token> required since 2025-07)
# Register at https://boardgamegeek.com/using_the_xml_api
BGG_API_TOKEN=your_bgg_api_token_here

# BGG account login (separate from BGG_API_TOKEN above) — needed only for the
# top-ranked-games CSV data dump, which requires a logged-in session rather
# than the API token. Used by scripts/export_prices.py.
BGG_USERNAME=your_bgg_username
BGG_PASSWORD=your_bgg_password

# Amazon PA API (optional — leave unset until credentials are available)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=your_associate_tag-20

# Wishlist scraper (automatic fallback, only used while AMAZON_ACCESS_KEY/SECRET_KEY above are unset)
WISHLIST_URL=https://www.amazon.com.br/hz/wishlist/ls/SNXDXF4S9XUI
