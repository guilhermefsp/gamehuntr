# Database
# Local:       postgresql+asyncpg://gamehunter:gamehunter@localhost:5432/gamehunter
# Neon (prod): postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://gamehunter:gamehunter@localhost:5432/gamehunter

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ludopedia
LUDOPEDIA_ACCESS_TOKEN=your_ludopedia_token_here

# Amazon PA API (optional — leave unset until credentials are available)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=your_associate_tag-20
AMAZON_COUNTRY=BR

# Wishlist scraper (bridge until PA API is ready)
# Set WISHLIST_ENABLED=true to activate; set to false once PA API keys are set
WISHLIST_ENABLED=false
WISHLIST_URL=https://www.amazon.com.br/hz/wishlist/ls/SNXDXF4S9XUI
